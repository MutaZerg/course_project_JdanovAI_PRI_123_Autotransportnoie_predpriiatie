@model VehicleCompany.Models.Vehicle

@{
    ViewData["Title"] = "Edit";
}
<h4>Изменить транспорт</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" id="vehicleForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Vehicle_info" class="control-label">Название транспорта</label>
                <input asp-for="Vehicle_info" class="form-control" />
                <span asp-validation-for="Vehicle_info" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="numberOfSeats" class="control-label">Количество мест</label>
                <input type="number" id="numberOfSeats" name="numberOfSeats" class="form-control"
                       min="1" value="@Model.Seats?.Count() ?? 4" required />
                <small class="form-text text-muted">Установить количество мест</small>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}