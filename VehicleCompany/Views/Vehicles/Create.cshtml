@model VehicleCompany.Models.Vehicle

@{
    ViewData["Title"] = "Create";
}

<h1>Создать транспорт</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" id="vehicleForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="Vehicle_info" class="control-label">Название</label>
                <input asp-for="Vehicle_info" class="form-control" />
                <span asp-validation-for="Vehicle_info" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="numberOfSeats" class="control-label">Количество мест</label>
                <input type="number" id="numberOfSeats" name="numberOfSeats" class="form-control" 
                       min="1" value="4" required />
                <small class="form-text text-muted">Укажите количество мест</small>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Создать" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Назад</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}