@model VehicleCompany.Models.BookTripViewModel
@{
    ViewData["Title"] = "Бронирование поездки";
}

<h1>Бронирование поездки на маршруте:</h1>
<p class="text-muted">С продолжительностью: @Model.Route.Travel_time | Ценой: @Model.Route.Price</p>

@if (Model.Route.RouteStops?.Any() == true)
{
    <p><strong>Stops:</strong>
        @string.Join(" → ", Model.Route.RouteStops.OrderBy(rs => rs.StopId).Select(rs => rs.Stop?.Name ?? "—"))
    </p>
}

<h2 class="mt-4">Поездки и доступные места</h2>

@if (!Model.TripsWithSeats.Any())
{
    <p>На маршруте не назначены поездки.</p>
}
else
{
    @foreach (var tws in Model.TripsWithSeats)
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>Поездка</strong> @tws.Trip.Id — @tws.Trip.Start_time.ToString("g") → @tws.Trip.End_time.ToString("g")
            </div>
            <div class="card-body">
                @if (!tws.AvailableSeats.Any())
                {
                    <p class="text-muted mb-0">Все места забронированны.</p>
                }
                else
                {
                    <p class="mb-2">Доступные места:</p>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var seat in tws.AvailableSeats)
                        {
                            <a asp-controller="Bookings" asp-action="Create" asp-route-tripId="@tws.Trip.Id" asp-route-seatId="@seat.Id" class="btn btn-outline-primary">Место @seat.Id</a>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</div>
