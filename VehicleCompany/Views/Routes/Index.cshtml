@model IEnumerable<VehicleCompany.Models.Route>
@using VehicleCompany.Models
@{
    var userPermissions = User.Claims
        .Where(c => c.Type == "Permission")
        .Select(c => c.Value)
        .ToList();
}
@{
    ViewData["Title"] = "Index";
    var sortOrder = ViewBag.SortOrder as string ?? "";
    var sortBy = ViewBag.SortBy as string ?? "";
}
@{
    ViewData["Title"] = "Index";
}

<h1>Маршруты</h1>



<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Найти маршруты</h5>
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get" class="row g-3">
                    <div class="col-md-5">
                        <label for="first_stop" class="form-label">Откуда:</label>
                        <input type="text" class="form-control" id="first_stop" name="first_stop"
                               value="@ViewBag.FirstStop" placeholder="Введите название остановки" />
                    </div>
                    <div class="col-md-5">
                        <label for="second_stop" class="form-label">Куда:</label>
                        <input type="text" class="form-control" id="second_stop" name="second_stop"
                               value="@ViewBag.SecondStop" placeholder="Введите название остановки" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Поиск
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
</div>
@if (userPermissions.Contains("create_route"))
{
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-success mt-4">
            <i class="bi bi-plus-circle"></i> Создать новый
        </a>
    </div>
}
<table class="table table-hover">
    <tbody>
        @foreach (var item in Model)
        {
            var stops = item.RouteStops?.Select(rs => rs.Stop).ToList() ?? new List<Stop>();
            var stopCount = stops.Count;
            var stopNames = string.Join(", ", stops.Select(s => s.Name));

            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Travel_time)
                    Продолжительность
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                    Цена
                </td>
                <td>
                    <span class="badge @(stopCount > 0 ? "bg-info" : "bg-secondary")">
                        @stopCount @(stopCount == 1 ? "Остоновка" : "Остоновки")
                    </span>
                </td>
                
                <td>
                    <div class="btn-group" role="group">
                        @if (userPermissions.Contains("edit_route"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                        }
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Подробности</a>
                        <a asp-action="BookTrip" asp-route-id="@item.Id" class="btn btn-sm btn-success">Забронировать поездку</a>
                        @if (userPermissions.Contains("delete_route"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.PageNumber <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pageNumber="@(ViewBag.PageNumber - 1)">
                    Предидущая
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pageNumber="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.PageNumber >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pageNumber="@(ViewBag.PageNumber + 1)">
                    Следующая
                </a>
            </li>
        </ul>
    </nav>
}