@model VehicleCompany.Models.Route

@{
    ViewData["Title"] = "Delete";
}

<h1>Удалить?</h1>

<div>
    <h4>Маршрут</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Продолжительность 
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Travel_time)
        </dd>
        <dt class = "col-sm-2">
            Цена
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-primary">Назад</a>
    </form>
</div>
